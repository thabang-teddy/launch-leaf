# /home/thabangt/public_html/launch-leaf/.htaccess
# Security only — blocks direct access to sensitive files and directories.

Options -Indexes

# Block .env and other sensitive root-level files
<FilesMatch "^(\.env.*|composer\.(json|lock)|artisan|package(-lock)?\.json|vite\.config\.js|phpunit\.xml)$">
    Order deny,allow
    Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct URL access to internal Laravel directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/.*)?$ - [F,L]
</IfModule>

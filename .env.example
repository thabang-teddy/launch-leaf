# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="LaunchLeaf"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Database — SQLite
# ─────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_DATABASE defaults to database/database.sqlite — override only if
# you want the file somewhere else, e.g.:
# DB_DATABASE=/absolute/path/to/database.sqlite

# ─────────────────────────────────────────────
# Session / Cache / Queue
# ─────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ─────────────────────────────────────────────
# GitHub Integration
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos) or public_repo (public only)
# ─────────────────────────────────────────────
GITHUB_TOKEN=

# ─────────────────────────────────────────────
# Mail — used for contact-form reply emails
# ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# Local dev override: log emails to storage/logs
# instead of sending them (comment out MAIL_* above)
# ─────────────────────────────────────────────
# MAIL_MAILER=log

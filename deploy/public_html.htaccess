# /home/thabangt/public_html/.htaccess
# Routes all domain traffic to the Laravel application's public directory.

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request already targets launch-leaf/public, stop here.
    # This prevents an infinite rewrite loop on re-processed requests.
    RewriteRule ^launch-leaf/public(/.*)?$ - [L,NC]

    # Route everything else into the Laravel public directory
    RewriteRule ^(.*)$ launch-leaf/public/$1 [L,QSA]
</IfModule>
